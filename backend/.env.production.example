PORT=8000
UVICORN_RELOAD=false
UVICORN_WORKERS=2
APP_ENV=production

# Domain backend publik wajib HTTPS
PUBLIC_BASE_URL=https://modiva.nurulfikri.id
PUBLIC_HOSTNAME=modiva.nurulfikri.id

# CORS tidak boleh "*" di production.
# Untuk mobile native murni, isi dengan domain frontend/admin jika ada.
CORS_ALLOW_ORIGINS=https://app.modiva.id,https://www.app.modiva.id

# Database production
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=modiva
MYSQL_USER=modiva_user
MYSQL_PASSWORD=CHANGE_ME_APP_PASSWORD
