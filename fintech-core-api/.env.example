ENVIRONMENT=development

# Auth service
AUTH_HTTP_ADDR=:8081
AUTH_GRPC_ADDR=:9091
MYSQL_DSN=fintech:fintech@tcp(mysql:3306)/authdb?parseTime=true
JWT_SECRET=change-me-with-a-strong-secret-at-least-32-bytes
JWT_TTL=24h
FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
EMAIL_HASH_SECRET=change-me-email-hmac-secret
BOOTSTRAP_ADMIN_EMAIL=admin@fintech.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!Secure

# Transaction service
TRANSACTION_HTTP_ADDR=:8082
POSTGRES_DSN=postgres://fintech:fintech@postgres:5432/txdb?sslmode=disable
AUTH_GRPC_TARGET=auth-service:9091

# Dashboard
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8081
NEXT_PUBLIC_TRANSACTION_API_URL=http://localhost:8082
