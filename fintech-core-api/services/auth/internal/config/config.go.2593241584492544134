package config

import (
	"os"
	"time"
)

type Config struct {
	Environment        string
	HTTPAddr           string
	GRPCAddr           string
	MySQLDSN           string
	JWTSecret          string
	JWTTTL             time.Duration
	FieldEncryptionKey string
	EmailHashSecret    string
	BootstrapAdminEmail    string
	BootstrapAdminPassword string
	AllowedOrigin      string
}

func Load() Config {
	return Config{
		Environment:        getEnv("ENVIRONMENT", "development"),
		HTTPAddr:           getEnv("AUTH_HTTP_ADDR", ":8081"),
		GRPCAddr:           getEnv("AUTH_GRPC_ADDR", ":9091"),
		MySQLDSN:           getEnv("MYSQL_DSN", "fintech:fintech@tcp(localhost:3306)/authdb?parseTime=true"),
		JWTSecret:          getEnv("JWT_SECRET", "local-development-secret-change-me"),
		JWTTTL:             getDuration("JWT_TTL", 24*time.Hour),
		FieldEncryptionKey: getEnv("FIELD_ENCRYPTION_KEY", "0123456789abcdef0123456789abcdef"),
		EmailHashSecret:    getEnv("EMAIL_HASH_SECRET", "local-email-hmac-secret-change-me"),
		BootstrapAdminEmail:    os.Getenv("BOOTSTRAP_ADMIN_EMAIL"),
		BootstrapAdminPassword: os.Getenv("BOOTSTRAP_ADMIN_PASSWORD"),
		AllowedOrigin:      getEnv("ALLOWED_ORIGIN", "*"),
	}
}

func getEnv(key, fallback string) string {
	value := os.Getenv(key)
	if value == "" {
		return fallback
	}
	return value
}

func getDuration(key string, fallback time.Duration) time.Duration {
	value := os.Getenv(key)
	if value == "" {
		return fallback
	}
	parsed, err := time.ParseDuration(value)
	if err != nil {
		return fallback
	}
	return parsed
}
