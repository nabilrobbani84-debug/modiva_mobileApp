package repository

import (
	"context"
	"database/sql"
	"errors"
	"strings"

	"github.com/go-sql-driver/mysql"

	"github.com/modiva/fintech-core-api/services/auth/internal/domain"
	"github.com/modiva/fintech-core-api/services/auth/internal/security"
)

type MySQLUserRepository struct {
	db          *sql.DB
	cipher      *security.FieldCipher
	hashSecret  string
}

func NewMySQLUserRepository(db *sql.DB, cipher *security.FieldCipher, hashSecret string) *MySQLUserRepository {
	return &MySQLUserRepository{db: db, cipher: cipher, hashSecret: hashSecret}
}

func (r *MySQLUserRepository) Create(ctx context.Context, user domain.User, passwordHash string) error {
	emailCipher, err := r.cipher.Encrypt(user.Email)
	if err != nil {
		return err
	}
	nameCipher, err := r.cipher.Encrypt(user.FullName)
	if err != nil {
		return err
	}

	_, err = r.db.ExecContext(ctx, `
		INSERT INTO users
			(id, email_hash, email_ciphertext, full_name_ciphertext, password_hash, role, status)
		VALUES (?, ?, ?, ?, ?, ?, ?)
	`, user.ID, security.HashEmail(r.hashSecret, strings.ToLower(user.Email)), emailCipher, nameCipher, passwordHash, user.Role, user.Status)
	if err != nil {
		var mysqlErr *mysql.MySQLError
		if errors.As(err, &mysqlErr) && mysqlErr.Number == 1062 {
			return domain.ErrDuplicateEmail
		}
		return err
	}
	return nil
}

func (r *MySQLUserRepository) FindByEmail(ctx context.Context, email string) (*domain.User, string, error) {
	row := r.db.QueryRowContext(ctx, `
		SELECT id, email_ciphertext, full_name_ciphertext, password_hash, role, status, created_at, updated_at
		FROM users
		WHERE email_hash = ?
	`, security.HashEmail(r.hashSecret, strings.ToLower(email)))
	return r.scanUserWithPassword(row)
}

func (r *MySQLUserRepository) FindByID(ctx context.Context, id string) (*domain.User, error) {
	row := r.db.QueryRowContext(ctx, `
		SELECT id, email_ciphertext, full_name_ciphertext, role, status, created_at, updated_at
		FROM users
		WHERE id = ?
	`, id)
	user, err := r.scanUser(row)
	if err != nil {
		return nil, err
	}
	return user, nil
}

func (r *MySQLUserRepository) scanUser(row *sql.Row) (*domain.User, error) {
	var user domain.User
	var emailCipher, nameCipher []byte
	var role, status string
	if err := row.Scan(&user.ID, &emailCipher, &nameCipher, &role, &status, &user.CreatedAt, &user.UpdatedAt); err != nil {
		if errors.Is(err, sql.ErrNoRows) {
			return nil, domain.ErrNotFound
		}
		return nil, err
	}
	email, err := r.cipher.Decrypt(emailCipher)
	if err != nil {
		return nil, err
	}
	name, err := r.cipher.Decrypt(nameCipher)
	if err != nil {
		return nil, err
	}
	user.Email = email
	user.FullName = name
	user.Role = domain.Role(role)
	user.Status = domain.Status(status)
	return &user, nil
}

func (r *MySQLUserRepository) scanUserWithPassword(row *sql.Row) (*domain.User, string, error) {
	var user domain.User
	var emailCipher, nameCipher []byte
	var role, status, passwordHash string
	if err := row.Scan(&user.ID, &emailCipher, &nameCipher, &passwordHash, &role, &status, &user.CreatedAt, &user.UpdatedAt); err != nil {
		if errors.Is(err, sql.ErrNoRows) {
			return nil, "", domain.ErrNotFound
		}
		return nil, "", err
	}
	email, err := r.cipher.Decrypt(emailCipher)
	if err != nil {
		return nil, "", err
	}
	name, err := r.cipher.Decrypt(nameCipher)
	if err != nil {
		return nil, "", err
	}
	user.Email = email
	user.FullName = name
	user.Role = domain.Role(role)
	user.Status = domain.Status(status)
	return &user, passwordHash, nil
}
